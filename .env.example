APP_NAME=LaravelAIQuiz
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8040
APP_INTERNAL_PORT=80
VITE_PORT=5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=ai_quiz
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Reverb WebSocket (Phase 4) — laravel/reverb
# Run `php artisan reverb:install` to generate REVERB_APP_ID/KEY/SECRET values.
# Included automatically in `composer run dev` as the 'reverb' process.
# -----------------------------------------------------------------------------
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# to avoid naming conflicts with other projects
COMPOSE_PROJECT_NAME=ai-quiz

SAIL_XDEBUG_MODE=develop,debug,coverage

# -----------------------------------------------------------------------------
# AI SDK (Phase 3) — laravel/ai
# Production priority:  Anthropic → Gemini → OpenAI
# Local dev fallback:   Ollama (no key required, works offline)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=          # Primary: Claude Sonnet (generation) / Haiku (grading, hints)
GEMINI_API_KEY=             # Secondary fallback
OPENAI_API_KEY=             # Tertiary fallback

# Ollama — local dev only (no key required, works fully offline)
# Available local models:
#   qwen2.5-coder:14b  — best for structured output / QuestionGeneratorAgent (9 GB)
#   qwen3:8b           — best for reasoning / AutoGraderAgent (5.2 GB)
#   gemma3:4b          — fastest / HintAgent streaming (3.3 GB)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# -----------------------------------------------------------------------------
# AI Rate Limiting & Cost Controls (Phase 5)
# -----------------------------------------------------------------------------
AI_RATE_LIMIT_PER_MINUTE=30
AI_DAILY_BUDGET=5.00